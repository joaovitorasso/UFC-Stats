# Copie este arquivo para .env e ajuste se necessário

# Caminho base de dados (padrão: ./data)
DATA_DIR=./data

# User-Agent para requests
USER_AGENT=Mozilla/5.0 (ufc-lakehouse; contact=you@example.com)

# Delay "educado" entre requisições (segundos)
POLITE_DELAY_SECONDS=0.6

# Timeout em segundos
HTTP_TIMEOUT_SECONDS=20

UFC_TARGET_SERVER=localhost\SQLEXPRESS
UFC_TARGET_DATABASE=UFC_Lakehouse
UFC_TARGET_SCHEMA=dbo
UFC_RAW_SCHEMA=raw
UFC_BRONZE_SCHEMA=bronze
UFC_SILVER_SCHEMA=silver
UFC_GOLD_SCHEMA=gold
UFC_TARGET_USER=
UFC_TARGET_PASSWORD=
UFC_TARGET_ENCRYPT=false
UFC_TARGET_TRUST_SERVER_CERTIFICATE=true
# Opcional: nome do driver ODBC (ex.: ODBC Driver 17 for SQL Server)
UFC_TARGET_ODBC_DRIVER=
# Opcional: parametros extras ODBC (ex.: MARS_Connection=Yes;Connection Timeout=30)
UFC_TARGET_ODBC_EXTRA=
